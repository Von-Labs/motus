EXPO_PUBLIC_ENV="DEVELOPMENT"

# Development API URL. Use:
# - http://localhost:3050  when app runs on same machine (e.g. web)
# - http://10.0.2.2:3050   when app runs on Android emulator (10.0.2.2 = host)
# - http://<YOUR_PC_IP>:3050  when app runs on physical device (e.g. http://192.168.1.100:3050)
# Then restart Expo (npx expo start -c). Ensure server is running and firewall allows port 3050.
EXPO_PUBLIC_DEV_API_URL="http://localhost:3050"

# Your production URL
EXPO_PUBLIC_PROD_API_URL="https://staging.example.com"